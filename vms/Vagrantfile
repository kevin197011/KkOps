# -*- mode: ruby -*-
# vi: set ft=ruby :

# Salt Master 和 Minion 虚拟机配置
# 使用 bento/ubuntu-24.04 镜像

# 网络配置
MASTER_IP = "192.168.56.10"
MINION_IP = "192.168.56.11"

# SSH 公钥路径（可选）
SSH_KEY_PATH = File.expand_path("~/.ssh/id_ed25519.pub")

Vagrant.configure("2") do |config|
  # 通用配置
  config.vm.box = "bento/ubuntu-24.04"
  config.vm.box_check_update = false

  # 如果存在 SSH 公钥，添加到虚拟机
  if File.exist?(SSH_KEY_PATH)
    ssh_pub_key = File.read(SSH_KEY_PATH).strip
    config.vm.provision "shell", inline: <<-SHELL
      mkdir -p /root/.ssh
      chmod 700 /root/.ssh
      echo '#{ssh_pub_key}' >> /root/.ssh/authorized_keys
      chmod 600 /root/.ssh/authorized_keys
      # 允许 root SSH 登录
      sed -i 's/#PermitRootLogin prohibit-password/PermitRootLogin yes/' /etc/ssh/sshd_config
      # Ubuntu 使用 ssh 而不是 sshd
      systemctl restart ssh
    SHELL
  end

  # Salt Master 虚拟机
  config.vm.define "salt-master" do |master|
    master.vm.hostname = "salt-master"
    master.vm.network "private_network", ip: MASTER_IP

    master.vm.provider "virtualbox" do |vb|
      vb.name = "salt-master"
      vb.memory = 2048
      vb.cpus = 2
    end

    # Salt Master 配置脚本
    master.vm.provision "shell", path: "scripts/provision-master.sh", env: {
      "MASTER_IP" => MASTER_IP
    }
  end

  # Salt Minion 虚拟机
  config.vm.define "salt-minion" do |minion|
    minion.vm.hostname = "salt-minion"
    minion.vm.network "private_network", ip: MINION_IP

    minion.vm.provider "virtualbox" do |vb|
      vb.name = "salt-minion"
      vb.memory = 1024
      vb.cpus = 1
    end

    # Salt Minion 配置脚本
    minion.vm.provision "shell", path: "scripts/provision-minion.sh", env: {
      "MASTER_IP" => MASTER_IP,
      "MINION_ID" => "minion-ubuntu-01"
    }
  end
end

